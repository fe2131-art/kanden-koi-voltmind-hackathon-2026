# Safety View Agent - Environment Variables Example

# ============================================
# OpenAI API Configuration
# ============================================
# Enable by setting llm.provider: "openai" in configs/default.yaml
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-5-nano

# ============================================
# vLLM Server Configuration (Local)
# ============================================
# Enable by setting llm.provider: "vllm" in configs/default.yaml
LLM_BASE_URL=http://localhost:8000
LLM_MODEL=your-local-model

# ============================================
# Development
# ============================================
PYTHONPATH=.
