# Safety View Agent - Environment Variables Example

# ============================================
# OpenAI API Authentication
# ============================================
# Required only if using OpenAI API (llm.provider: "openai" in configs/default.yaml)
# Model and base URL are configured in configs/default.yaml (llm.openai.model, etc.)
OPENAI_API_KEY=sk-your-api-key-here

# ============================================
# LLM Configuration
# ============================================
# All LLM settings (model, base_url) are configured in configs/default.yaml
# - For OpenAI: llm.openai.model, llm.openai.base_url
# - For vLLM: llm.vllm.model, llm.vllm.base_url

# ============================================
# Development
# ============================================
PYTHONPATH=.
